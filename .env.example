# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=rural_learning

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Sync
SYNC_BATCH_SIZE=50
SYNC_CONFLICT_STRATEGY=server_wins

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
