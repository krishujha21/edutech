{
    "version": 2,
    "installCommand": "npm install && cd server && npm install && cd ../client && npm install",
    "buildCommand": "cd client && npm run build",
    "outputDirectory": "client/build",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "env": {
        "VERCEL": "1"
    }
}