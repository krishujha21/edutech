{
    "name": "rural-learning-system",
    "version": "1.0.0",
    "description": "Offline-First Rural Learning System for Class 5-10",
    "private": true,
    "scripts": {
        "server": "cd server && npm start",
        "server:dev": "cd server && npm run dev",
        "client": "cd client && npm start",
        "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
        "install:all": "npm install && cd server && npm install && cd ../client && npm install",
        "build": "cd client && npm install && npm run build"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "uuid": "^10.0.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}